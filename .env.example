# ==============================================================================
# Chawkidaar Environment Configuration Example
# Copy this file to .env and configure local environment variables.
# ==============================================================================

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# Database Configuration
DATABASE_URL=sqlite:///./chawkidaar.db

# Telegram Notification Settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
